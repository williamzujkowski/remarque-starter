---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + "/";
---

<BaseLayout title="Writing" description="Long-form essays.">
  <div class="pt-[var(--space-9)] content-reading">
    <h1 class="text-display font-display text-[var(--color-fg)]">Writing</h1>
    <p class="mt-4 font-mono text-[var(--text-meta)] tracking-[var(--tracking-meta)] text-[var(--color-muted)]">
      1 essay.
    </p>
  </div>

  <div class="mt-12 content-reading space-y-8">
    <article class="pb-8 border-b border-[var(--color-border)]">
      <a href={`${base}writing/hello-world`} class="group block">
        <h2 class="text-title font-display text-[var(--color-fg)] group-hover:text-[var(--color-accent)] transition-colors duration-[var(--motion-fast)]">Hello, World</h2>
        <div class="mt-2 font-mono text-[var(--text-meta)] tracking-[var(--tracking-meta)] text-[var(--color-muted)] flex gap-4">
          <time datetime="2026-07-20">Jul 20, 2026</time>
          <span>1 min read</span>
        </div>
        <p class="mt-3 text-[var(--text-body)] text-[var(--color-fg-muted)]">
          A placeholder essay demonstrating the Essay archetype — replace it with your first post.
        </p>
      </a>
    </article>
  </div>
</BaseLayout>
