---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Projects" description="Technical work and open source.">
  <div class="pt-[var(--space-9)]">
    <h1 class="text-display font-display text-[var(--color-fg)]">Projects</h1>
    <p class="mt-4 font-mono text-[var(--text-meta)] tracking-[var(--tracking-meta)] text-[var(--color-muted)]">
      Technical work, open source, and experiments.
    </p>
  </div>

  <div class="mt-12 space-y-8">
    <a href={`${base}projects/example-project`} class="group block pb-8 border-b border-[var(--color-border)]">
      <h2 class="text-title font-display text-[var(--color-fg)] group-hover:text-[var(--color-accent)] transition-colors duration-[var(--motion-fast)]">Example Project</h2>
      <div class="mt-2 font-mono text-[var(--text-meta)] tracking-[var(--tracking-meta)] text-[var(--color-muted)] flex gap-4">
        <span>active</span>
        <span>Astro / TypeScript</span>
        <time datetime="2026-07-20">Jul 20, 2026</time>
      </div>
      <p class="mt-3 text-[var(--text-body)] text-[var(--color-fg-muted)]">
        A placeholder project dossier — replace it with a real one.
      </p>
    </a>
  </div>
</BaseLayout>
